{
  "name": "arb-token-bridge-ui-mono",
  "private": true,
  "license": "UNLICENSED",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --filter app dev",
    "build": "pnpm --filter app build",
    "start": "pnpm --filter app start",
    "audit:ci": "audit-ci --config ./audit-ci.jsonc",
    "test:ci": "pnpm --filter arb-token-bridge-ui test:ci",
    "prettier:check": "prettier --check .",
    "prettier:format": "prettier --write .",
    "lint": "tsc && eslint",
    "lint:fix": "tsc && eslint --quiet --fix",
    "postinstall": "pnpm run install:chromium",
    "install:chromium": "pnpm dlx @puppeteer/browsers install chrome@$npm_package_config_chromeVersion --path $npm_package_config_chromePath",
    "test:e2e": "pnpm --filter arb-token-bridge-ui exec env-cmd --silent --file .e2e.env pnpm exec synpress run --configFile synpress.config.ts",
    "test:e2e:cctp": "pnpm run test:e2e --configFile synpress.cctp.config.ts",
    "test:e2e:orbit": "E2E_ORBIT=true pnpm run test:e2e",
    "test:e2e:orbit:custom-gas-token": "E2E_ORBIT_CUSTOM_GAS_TOKEN=true pnpm run test:e2e"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "core-js",
      "core-js-pure",
      "cypress",
      "esbuild",
      "keccak",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ],
    "overrides": {
      "node-forge": "1.4.0",
      "@types/node-forge": "1.3.14",
      "@walletconnect/ethereum-provider": "2.13.1",
      "@octokit/core>@octokit/request-error": "5.1.1",
      "@octokit/core>@octokit/request": "8.4.1",
      "@octokit/graphql>@octokit/request": "8.4.1",
      "@actions/github>@octokit/plugin-paginate-rest": "9.2.2",
      "react-syntax-highlighter>prismjs": "1.30.0",
      "refractor>prismjs": "1.30.0",
      "@babel/runtime": "7.26.10",
      "tar-fs": "2.1.4",
      "sharp>tar-fs": "3.0.9",
      "form-data": "4.0.4",
      "axios": "1.13.5",
      "@eslint/plugin-kit": "0.3.4",
      "@types/react": "18.2.12",
      "@types/react-dom": "18.3.7",
      "js-yaml": "4.1.1",
      "undici": "6.24.0",
      "h3": "1.15.10",
      "lodash": "4.17.23",
      "lodash-es": "4.17.23",
      "sha.js": "2.4.12",
      "bn.js": "5.2.3",
      "flatted": "3.4.2",
      "brace-expansion": "1.1.13",
      "@typescript-eslint/*>brace-expansion": "5.0.5",
      "utf-8-validate": "6.0.6"
    }
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@offchainlabs/eslint-config-typescript": "0.2.2",
    "@offchainlabs/prettier-config": "0.3.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.5.0",
    "audit-ci": "^6.3.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-zustand-rules": "https://github.com/OffchainLabs/eslint-plugin-zustand-rules",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.8.3"
  },
  "config": {
    "chromeVersion": "128.0.6613.137",
    "chromePath": "node_modules/.cache/synpress"
  }
}
